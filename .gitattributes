# Normalize all text files to LF on commit (prevents CRLF warnings on Windows)
* text=auto eol=lf

# Source and config files — always LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.conf  text eol=lf

# Windows scripts — CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
