# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.

# Port the backend HTTP server listens on
PORT=4000

# Telemetry broadcast interval in milliseconds (min: 100)
TICK_MS=3000

# RPM value that triggers an ALERT status
ALERT_RPM=6000

# Temperature (°C) that triggers an ALERT status
ALERT_TEMP=90

# Maximum number of alarms stored in the in-memory ring buffer
ALARM_BUFFER=100

# Comma-separated list of allowed CORS origins.
# Defaults to http://localhost:5173,http://localhost:3000 when not set.
# Example for Docker Compose: http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
